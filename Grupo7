<!DOCTYPE html>
<html>
<head>
	<meta charset="UTF-8">
	<title>Missão JavaScript</title>
</head>

<body>
	<h1>Sistema de Teste da Startup</h1>
	<button onclick="iniciarSistema()">Iniciar</button>

	<div id="saida"></div>

<script>

function iniciarSistema(){

//Solicitar dado ao usuário
var distancia = Number(prompt("Insira a distância da viagem em km"));

var precoKm = 3;
var preco = distancia * precoKm;
var desconto = 0;

if(distancia <= 50){
	console.log("Sem desconto");
}

else if(distancia >= 51 && distancia <= 100){
	desconto = preco * 0.10;
}

else if(distancia >= 150){
	desconto = preco * 0.15;
}

var valorFinal = preco - desconto;

console.log("Preço final: R$ " + valorFinal);

}

</script>

</body>
</html>





