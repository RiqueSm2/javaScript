        distancia: distancia
    };
}

function calcularDesconto(distancia){
    const precoPorKm = 3;
    let preco = distancia * precoPorKm;
    let desconto = 0;

    if(distancia <= 50){
        desconto = 0; // sem desconto
    } 
    else if(distancia >= 51 && distancia <= 100){
        desconto = preco * 0.10; // 10% de desconto
    } 
    else if(distancia >= 150){
        desconto = preco * 0.15; // 15% de desconto
    }

    let valorFinal = preco - desconto;
    return valorFinal;
}

function classificar(duracao){
    if(duracao <= 40){
        return "Perto";      
    }
    else if(duracao <= 90){
        return "Médio";      
    }
    else{
        return "Longe";       
    }
}

